@model FindActivity.Web.Models.Profile.ProfileEditViewModel
@{
    ViewData["Title"] = "Edit profile";
}

<h1>Edit profile</h1>

<form method="post" enctype="multipart/form-data" class="col-lg-7">
    <input type="hidden" asp-for="AvatarPath" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="card mb-3 p-3">
        <label class="form-label" asp-for="AvatarFile"></label>
        <div class="d-flex align-items-center gap-3 mb-2">
            <span class="fa-avatar fa-avatar-lg">
                @if (!string.IsNullOrWhiteSpace(Model.AvatarPath))
                {
                    <img src="@Model.AvatarPath" alt="Current avatar" />
                }
                else
                {
                    <span>?</span>
                }
            </span>
            <div class="flex-grow-1">
                <input class="form-control" type="file" asp-for="AvatarFile" accept="image/jpeg,image/png,image/webp" />
                <small class="text-muted">JPG, PNG, or WebP. Max 3MB. Square crops look best.</small>
                <span asp-validation-for="AvatarFile" class="text-danger d-block"></span>
            </div>
        </div>
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="DisplayName"></label>
        <input class="form-control" asp-for="DisplayName" />
        <span asp-validation-for="DisplayName" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label" asp-for="Bio"></label>
        <textarea class="form-control" asp-for="Bio" rows="4"></textarea>
        <span asp-validation-for="Bio" class="text-danger"></span>
    </div>

    <div class="d-flex flex-wrap gap-2">
        <button class="btn btn-primary rounded-pill px-4" type="submit">Save</button>
        <a class="btn btn-link" asp-action="Details">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
