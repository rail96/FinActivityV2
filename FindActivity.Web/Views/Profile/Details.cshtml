@model FindActivity.Web.Models.Profile.ProfileDetailsViewModel
@using FindActivity.Domain.Enums
@using FindActivity.Web.Models.Reports
@{
    ViewData["Title"] = "Profile";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canReportUser = User.Identity?.IsAuthenticated == true
                        && currentUserId is not null
                        && Model.User.Id != currentUserId;
}

@if (TempData["ReportSuccess"] is string reportSuccess)
{
    <div class="alert alert-success" role="alert">@reportSuccess</div>
}
@if (TempData["ReportError"] is string reportError)
{
    <div class="alert alert-danger" role="alert">@reportError</div>
}
@if (TempData["ProfileMessage"] is string profileMessage)
{
    <div class="alert alert-success" role="alert">@profileMessage</div>
}

@{
    var isOwnProfile = currentUserId is not null && Model.User.Id == currentUserId;
}

@{
    var profileInitial = string.IsNullOrWhiteSpace(Model.User.DisplayName)
        ? (Model.User.UserName ?? "?").Substring(0, 1).ToUpperInvariant()
        : Model.User.DisplayName.Substring(0, 1).ToUpperInvariant();
}

<div class="d-flex align-items-center gap-3 flex-wrap mb-3">
    <span class="fa-avatar fa-avatar-lg">
        @if (!string.IsNullOrWhiteSpace(Model.User.AvatarPath))
        {
            <img src="@Model.User.AvatarPath" alt="@Model.User.DisplayName" />
        }
        else
        {
            @profileInitial
        }
    </span>
    <div class="flex-grow-1">
        <h1 class="d-flex align-items-center gap-2 mb-1">
            <span>@(Model.User.DisplayName ?? Model.User.UserName)</span>
            @if (Model.User.PhoneNumberConfirmed)
            {
                <span class="badge bg-success" title="Phone verified">&#10003; Verified</span>
            }
        </h1>
        @if (Model.User.RatingCount > 0)
        {
            <div class="text-muted small">@Model.User.RatingAvg.ToString("0.0") &middot; @Model.User.RatingCount review@(Model.User.RatingCount == 1 ? "" : "s")</div>
        }
    </div>
    @if (isOwnProfile)
    {
        <a class="btn btn-outline-primary rounded-pill" asp-action="Edit">Edit profile</a>
    }
</div>

@if (isOwnProfile && !Model.User.PhoneNumberConfirmed)
{
    <div class="alert alert-info d-flex justify-content-between align-items-center" role="alert">
        <span>Verify your phone number to earn a Verified badge on your profile and activities.</span>
        <a class="btn btn-sm btn-primary" asp-controller="PhoneVerification" asp-action="Start">Verify your phone</a>
    </div>
}

<p>@Model.User.Bio</p>

<dl class="row">
    <dt class="col-sm-3">Birth date</dt>
    <dd class="col-sm-9">@(Model.User.BirthDate?.ToString("yyyy-MM-dd") ?? "N/A")</dd>
    <dt class="col-sm-3">Rating</dt>
    <dd class="col-sm-9">@Model.User.RatingAvg.ToString("0.0") (@Model.User.RatingCount)</dd>
</dl>

<h3>Reviews</h3>
@if (Model.Reviews.Count == 0)
{
    <p>No reviews yet.</p>
}
else
{
    <div class="list-group">
        @foreach (var review in Model.Reviews)
        {
            <div class="list-group-item">
                <div class="d-flex justify-content-between">
                    <strong>Rating: @review.Rating</strong>
                    <span class="text-muted">@review.CreatedUtc.ToString("u")</span>
                </div>
                <p class="mb-1">@review.Comment</p>
                <a asp-controller="Activities" asp-action="Details" asp-route-id="@review.ActivityId">View activity</a>
            </div>
        }
    </div>
}

@if (canReportUser)
{
    var reportModel = new ReportCreateViewModel
    {
        TargetType = ReportTargetType.User,
        TargetUserId = Model.User.Id,
        ReturnUrl = Url.Action("Details", "Profile", new { id = Model.User.Id })
    };
    <div class="mt-4">
        <button type="button" class="btn btn-link text-muted p-0" data-bs-toggle="modal" data-bs-target="#reportModal">
            Report this user
        </button>
    </div>
    <partial name="_ReportModal" model="reportModel" />
}
