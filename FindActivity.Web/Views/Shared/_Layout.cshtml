<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FindActivity.Web</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/brand.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FindActivity.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-md navbar-light bg-white">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-controller="Activities" asp-action="Index">
                    <svg class="brand-pin" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M12 2C7.59 2 4 5.59 4 10c0 6 8 12 8 12s8-6 8-12c0-4.41-3.59-8-8-8zm0 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6z" />
                    </svg>
                    FindActivity
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"
                        aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse" id="mainNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Activities" asp-action="Index">Activities</a>
                        </li>
                    </ul>
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - FindActivity
            &middot; <a asp-area="" asp-controller="Home" asp-action="Terms">Terms</a>
            &middot; <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            &middot; <a asp-area="" asp-controller="Home" asp-action="CommunityGuidelines">Community Guidelines</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/activity-location.js" asp-append-version="true"></script>
    <script>
        if (!window.__activityLocationLoaded) {
            const help = document.querySelector("[data-address-help]");
            if (help) {
                help.textContent = "Address suggestions script not loaded.";
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
