@model FindActivity.Web.Models.PhoneVerification.PhoneConfirmViewModel
@{
    ViewData["Title"] = "Enter your code";
}

<h1>Enter your code</h1>

<p class="text-muted">We sent a 6-digit code to <strong>@Model.PhoneNumber</strong>. Codes expire in 10 minutes.</p>

<form method="post" class="col-md-6">
    <input type="hidden" asp-for="PhoneNumber" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label class="form-label" asp-for="Code"></label>
        <input class="form-control" asp-for="Code" inputmode="numeric" autocomplete="one-time-code" pattern="[0-9]*" maxlength="10" placeholder="123456" />
        <span asp-validation-for="Code" class="text-danger"></span>
    </div>
    <button class="btn btn-primary" type="submit">Verify</button>
    <a class="btn btn-link" asp-action="Start">Use a different number</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
