@model FindActivity.Web.Models.Activities.MyHostedViewModel
@using FindActivity.Domain.Enums
@{
    ViewData["Title"] = "My hosted activities";

    string TabClass(ActivityStatus? status) =>
        Model.FilterStatus == status ? "nav-link active" : "nav-link";

    string FormatStartUtc(DateTime startUtc)
    {
        var diff = startUtc - DateTime.UtcNow;
        if (diff.TotalMinutes < -1)
        {
            var ago = -diff;
            if (ago.TotalDays >= 1) return $"{(int)ago.TotalDays}d ago";
            if (ago.TotalHours >= 1) return $"{(int)ago.TotalHours}h ago";
            return "just now";
        }
        if (diff.TotalDays >= 1) return $"in {(int)diff.TotalDays}d";
        if (diff.TotalHours >= 1) return $"in {(int)diff.TotalHours}h";
        return "starting soon";
    }

    string CapacityBarColor(int joined, int capacity) =>
        capacity == 0 ? "bg-secondary"
            : joined >= capacity ? "bg-warning"
            : joined >= capacity * 0.75 ? "bg-info"
            : "bg-success";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">My hosted activities</h1>
    <a class="btn btn-primary" asp-action="Create">+ New activity</a>
</div>

<ul class="nav nav-pills mb-3">
    <li class="nav-item">
        <a class="@TabClass(null)" asp-action="MyHosted">
            All <span class="badge bg-light text-dark">@Model.TotalCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="@TabClass(ActivityStatus.Scheduled)" asp-action="MyHosted" asp-route-status="@((int)ActivityStatus.Scheduled)">
            Scheduled <span class="badge bg-light text-dark">@Model.ScheduledCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="@TabClass(ActivityStatus.Completed)" asp-action="MyHosted" asp-route-status="@((int)ActivityStatus.Completed)">
            Completed <span class="badge bg-light text-dark">@Model.CompletedCount</span>
        </a>
    </li>
    <li class="nav-item">
        <a class="@TabClass(ActivityStatus.Cancelled)" asp-action="MyHosted" asp-route-status="@((int)ActivityStatus.Cancelled)">
            Cancelled <span class="badge bg-light text-dark">@Model.CancelledCount</span>
        </a>
    </li>
</ul>

@if (!Model.Activities.Any())
{
    <div class="alert alert-light border" role="alert">
        @if (Model.FilterStatus is null)
        {
            <span>You haven't hosted any activities yet. </span>
            <a asp-action="Create">Host one now &rarr;</a>
        }
        else
        {
            <span>No @Model.FilterStatus.ToString().ToLower() activities.</span>
        }
    </div>
}
else
{
    <div class="row g-3">
    @foreach (var activity in Model.Activities)
    {
        var joinedPct = activity.Capacity == 0 ? 0 : Math.Min(100, (int)Math.Round((double)activity.JoinedCount / activity.Capacity * 100));
        var endUtc = activity.StartUtc.AddMinutes(activity.DurationMinutes);
        var canEdit = activity.Status == ActivityStatus.Scheduled;
        var canCancel = activity.Status == ActivityStatus.Scheduled;
        var canComplete = activity.Status == ActivityStatus.Scheduled && endUtc <= DateTime.UtcNow;

        <div class="col-12 col-md-6">
            <div class="card h-100 shadow-sm">
                @if (!string.IsNullOrWhiteSpace(activity.CoverImagePath))
                {
                    <a asp-action="Details" asp-route-id="@activity.Id">
                        <img src="@activity.CoverImagePath" alt="Cover for @activity.Title"
                             class="card-img-top" style="height: 160px; object-fit: cover;" />
                    </a>
                }
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="card-title mb-0">
                            <a class="text-reset text-decoration-none" asp-action="Details" asp-route-id="@activity.Id">@activity.Title</a>
                        </h5>
                        <span class="badge bg-@(activity.Status switch {
                            ActivityStatus.Scheduled => "primary",
                            ActivityStatus.Completed => "success",
                            ActivityStatus.Cancelled => "secondary",
                            _ => "light"
                        })">@activity.Status</span>
                    </div>

                    <div class="text-muted small mb-2">
                        @activity.CategoryName &middot; @activity.City, @activity.State
                    </div>

                    <div class="mb-2">
                        <strong>@activity.StartUtc.ToString("ddd MMM d, HH:mm")</strong>
                        <span class="text-muted">UTC &middot; @FormatStartUtc(activity.StartUtc) &middot; @activity.DurationMinutes min</span>
                    </div>

                    <div class="mb-3">
                        <div class="d-flex justify-content-between small mb-1">
                            <span>@activity.JoinedCount / @activity.Capacity joined</span>
                            @if (activity.WaitlistedCount > 0)
                            {
                                <span class="text-info">@activity.WaitlistedCount on waitlist</span>
                            }
                        </div>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar @CapacityBarColor(activity.JoinedCount, activity.Capacity)"
                                 role="progressbar"
                                 style="width: @joinedPct%"
                                 aria-valuenow="@joinedPct" aria-valuemin="0" aria-valuemax="100"></div>
                        </div>
                    </div>

                    <div class="mt-auto d-flex flex-wrap gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-action="Details" asp-route-id="@activity.Id">View</a>
                        @if (canEdit)
                        {
                            <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@activity.Id">Edit</a>
                        }
                        @if (canCancel)
                        {
                            <form asp-action="Cancel" asp-route-id="@activity.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-danger" type="submit"
                                        onclick="return confirm('Cancel this activity? Participants will be notified.');">Cancel</button>
                            </form>
                        }
                        @if (canComplete)
                        {
                            <form asp-action="Complete" asp-route-id="@activity.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-sm btn-outline-success" type="submit">Mark complete</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    </div>
}
