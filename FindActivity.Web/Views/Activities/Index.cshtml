@model FindActivity.Web.Models.Activities.ActivitySearchViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Activities";
    var isMapView = string.Equals(Model.View, "map", StringComparison.OrdinalIgnoreCase);

    // Build the same querystring (sans View) so the toggle preserves the user's filters.
    var qs = new Dictionary<string, string?>
    {
        { "City", Model.City },
        { "CategoryId", Model.CategoryId?.ToString() },
        { "StartUtcFrom", Model.StartUtcFrom?.ToString("o") },
        { "StartUtcTo", Model.StartUtcTo?.ToString("o") },
        { "MaxDistanceKm", Model.MaxDistanceKm?.ToString() }
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="mb-0">Activities</h1>
    <div class="btn-group" role="group" aria-label="View toggle">
        <a class="btn @(isMapView ? "btn-outline-primary" : "btn-primary")"
           asp-action="Index"
           asp-all-route-data="@qs">List</a>
        <a class="btn @(isMapView ? "btn-primary" : "btn-outline-primary")"
           asp-action="Index"
           asp-all-route-data="@(qs.Concat(new[] { new KeyValuePair<string, string?>("View", "map") }).ToDictionary(p => p.Key, p => p.Value))">Map</a>
    </div>
</div>

<form method="get" class="card card-body mb-4">
    <input type="hidden" asp-for="View" />
    <div class="row g-3">
        <div class="col-12 col-md-4 col-lg-3">
            <label class="form-label">City</label>
            <input class="form-control" asp-for="City" placeholder="e.g. Seattle" />
        </div>
        <div class="col-12 col-md-4 col-lg-3">
            <label class="form-label">Category</label>
            <select class="form-select" asp-for="CategoryId" asp-items="Model.Categories">
                <option value="">All</option>
            </select>
        </div>
        <div class="col-12 col-md-4 col-lg-2">
            <label class="form-label">Distance from Seattle</label>
            <select class="form-select" asp-for="MaxDistanceKm">
                <option value="">Any</option>
                <option value="5">Within 5 km</option>
                <option value="10">Within 10 km</option>
                <option value="25">Within 25 km</option>
                <option value="50">Within 50 km</option>
            </select>
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <label class="form-label">Start from (UTC)</label>
            <input class="form-control" type="datetime-local" asp-for="StartUtcFrom" />
        </div>
        <div class="col-6 col-md-4 col-lg-2">
            <label class="form-label">Start to (UTC)</label>
            <input class="form-control" type="datetime-local" asp-for="StartUtcTo" />
        </div>
    </div>
    <div class="d-flex justify-content-between align-items-center mt-3">
        <a class="btn btn-link p-0" asp-action="Index">Clear filters</a>
        <button class="btn btn-primary" type="submit">Search</button>
    </div>
</form>

<div class="mb-3">
    <a class="btn btn-success" asp-action="Create">Create activity</a>
</div>

@if (isMapView)
{
    <div class="mb-4">
        <div id="activity-map" class="activity-map" style="height: 540px;" data-mapbox-token="@Configuration["Mapbox:AccessToken"]"></div>
    </div>
    @if (!Model.Results.Any())
    {
        <p class="text-muted">No activities match your filters.</p>
    }
    else if (!Model.Results.Any(r => r.Latitude.HasValue && r.Longitude.HasValue))
    {
        <p class="text-muted small">None of the matching activities have coordinates yet. Older activities may need to be re-saved with an address.</p>
    }
}
else
{
    @if (!Model.Results.Any())
    {
        <p class="text-muted">No activities match your filters.</p>
    }
    else
    {
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Title</th>
                    <th>City</th>
                    <th>State</th>
                    <th>Category</th>
                    <th>Start (UTC)</th>
                    <th>Capacity</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Results)
            {
                <tr>
                    <td>
                        <div class="d-flex align-items-center gap-2">
                            @if (!string.IsNullOrWhiteSpace(item.CoverImagePath))
                            {
                                <img src="@item.CoverImagePath" alt="" style="width: 48px; height: 48px; object-fit: cover; border-radius: 4px;" />
                            }
                            else
                            {
                                <div style="width: 48px; height: 48px; background:#f0f0f0; border-radius: 4px;"></div>
                            }
                            <span>@item.Title</span>
                        </div>
                    </td>
                    <td>@item.City</td>
                    <td>@item.State</td>
                    <td>@item.CategoryName</td>
                    <td>@item.StartUtc.ToString("u")</td>
                    <td>@item.JoinedCount / @item.Capacity</td>
                    <td>@item.Status</td>
                    <td><a asp-action="Details" asp-route-id="@item.Id">Details</a></td>
                </tr>
            }
            </tbody>
        </table>
    }
}

@section Styles {
    @if (isMapView)
    {
        <link href="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.css" rel="stylesheet" />
    }
}

@section Scripts {
    @if (isMapView)
    {
        <script src="https://api.mapbox.com/mapbox-gl-js/v2.15.0/mapbox-gl.js"></script>
        <script type="application/json" id="activity-map-data">
            @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                Model.Results.Select(item => new
                {
                    title = item.Title,
                    address = item.Address,
                    city = item.City,
                    state = item.State,
                    latitude = item.Latitude,
                    longitude = item.Longitude,
                    coverImage = item.CoverImagePath,
                    detailsUrl = Url.Action("Details", new { id = item.Id })
                })
            ))
        </script>
        <script src="~/js/activity-map.js" asp-append-version="true"></script>
    }
}
