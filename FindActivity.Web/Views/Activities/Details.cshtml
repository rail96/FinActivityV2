@model FindActivity.Web.Models.Activities.ActivityDetailsViewModel
@using FindActivity.Domain.Enums
@using FindActivity.Web.Models.Reports
@{
    ViewData["Title"] = Model.Activity.Title;
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var canReportActivity = User.Identity?.IsAuthenticated == true
                            && currentUserId is not null
                            && Model.Activity.CreatedByUserId != currentUserId;
}

@if (TempData["ReportSuccess"] is string reportSuccess)
{
    <div class="alert alert-success" role="alert">@reportSuccess</div>
}
@if (TempData["ReportError"] is string reportError)
{
    <div class="alert alert-danger" role="alert">@reportError</div>
}
@if (TempData["JoinMessage"] is string joinMessage)
{
    <div class="alert alert-info" role="alert">@joinMessage</div>
}
@if (TempData["JoinError"] is string joinError)
{
    <div class="alert alert-danger" role="alert">@joinError</div>
}

<h1>@Model.Activity.Title</h1>

@if (!string.IsNullOrWhiteSpace(Model.Activity.CoverImagePath))
{
    <div class="mb-3">
        <img src="@Model.Activity.CoverImagePath" alt="Cover image for @Model.Activity.Title"
             class="img-fluid rounded" style="max-height: 360px; object-fit: cover; width: 100%;" />
    </div>
}

<div class="mb-3">
    <span class="badge bg-secondary">@Model.Activity.Status</span>
    <span class="ms-2">@Model.Activity.CategoryName</span>
</div>

<dl class="row">
    <dt class="col-sm-3">Start (UTC)</dt>
    <dd class="col-sm-9">@Model.Activity.StartUtc.ToString("u")</dd>
    <dt class="col-sm-3">Duration</dt>
    <dd class="col-sm-9">@Model.Activity.DurationMinutes minutes</dd>
    <dt class="col-sm-3">Location</dt>
    <dd class="col-sm-9">@Model.Activity.Address, @Model.Activity.City, @Model.Activity.State</dd>
    <dt class="col-sm-3">Capacity</dt>
    <dd class="col-sm-9">
        @Model.Activity.JoinedCount / @Model.Activity.Capacity joined
        @if (Model.Activity.WaitlistedCount > 0)
        {
            <span class="text-muted">&middot; @Model.Activity.WaitlistedCount on waitlist</span>
        }
        @if (Model.Activity.IsUserWaitlisted)
        {
            <div><span class="badge bg-info">You're #@Model.Activity.UserWaitlistPosition on the waitlist</span></div>
        }
    </dd>
    <dt class="col-sm-3">Minimum age</dt>
    <dd class="col-sm-9">@(Model.Activity.MinAge?.ToString() ?? "None")</dd>
    <dt class="col-sm-3">Host</dt>
    <dd class="col-sm-9">
        @{
            var hostName = Model.Activity.HostDisplayName ?? "Host";
            var hostInitial = string.IsNullOrWhiteSpace(hostName) ? "?" : hostName.Substring(0, 1).ToUpperInvariant();
        }
        <a asp-controller="Profile" asp-action="Details" asp-route-id="@Model.Activity.CreatedByUserId"
           class="d-inline-flex align-items-center gap-2 text-decoration-none text-reset">
            <span class="fa-avatar fa-avatar-sm">
                @if (!string.IsNullOrWhiteSpace(Model.Activity.HostAvatarPath))
                {
                    <img src="@Model.Activity.HostAvatarPath" alt="@hostName" />
                }
                else
                {
                    @hostInitial
                }
            </span>
            <span>@hostName</span>
            @if (Model.Activity.HostPhoneVerified)
            {
                <span class="badge bg-success" title="Host has verified their phone">&#10003; Verified</span>
            }
        </a>
    </dd>
</dl>

<p>@Model.Activity.Description</p>

@if (User.Identity?.IsAuthenticated == true && (Model.IsCreator || Model.Activity.IsUserJoined))
{
    var joinedList = Model.Activity.Participants.Where(p => p.Status == ParticipantStatus.Joined).ToList();
    var waitlistedList = Model.Activity.Participants.Where(p => p.Status == ParticipantStatus.Waitlisted).ToList();

    <div class="mt-4">
        <h5>Participants (@joinedList.Count)</h5>
        @if (!joinedList.Any())
        {
            <p class="text-muted mb-0">No participants yet.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Rating</th>
                            <th>Bio</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var participant in joinedList)
                    {
                        var ratingLabel = participant.RatingCount == 0
                            ? "No ratings yet"
                            : $"{participant.RatingAvg:0.0} ({participant.RatingCount})";
                        var participantInitial = string.IsNullOrWhiteSpace(participant.DisplayName) ? "?" : participant.DisplayName.Substring(0, 1).ToUpperInvariant();
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <span class="fa-avatar fa-avatar-sm">
                                        @if (!string.IsNullOrWhiteSpace(participant.AvatarPath))
                                        {
                                            <img src="@participant.AvatarPath" alt="" />
                                        }
                                        else
                                        {
                                            @participantInitial
                                        }
                                    </span>
                                    <span>@participant.DisplayName</span>
                                </div>
                            </td>
                            <td>@ratingLabel</td>
                            <td>@(string.IsNullOrWhiteSpace(participant.Bio) ? "—" : participant.Bio)</td>
                            <td>
                                <a asp-controller="Profile" asp-action="Details" asp-route-id="@participant.UserId">View profile</a>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>

    @if (Model.IsCreator && waitlistedList.Any())
    {
        <div class="mt-4">
            <h5>Waitlist (@waitlistedList.Count)</h5>
            <p class="text-muted small mb-2">Listed in queue order. The next person is auto-promoted when a spot opens.</p>
            <div class="table-responsive">
                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Rating</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @{ var pos = 1; }
                    @foreach (var participant in waitlistedList)
                    {
                        var ratingLabel = participant.RatingCount == 0
                            ? "No ratings yet"
                            : $"{participant.RatingAvg:0.0} ({participant.RatingCount})";
                        <tr>
                            <td>@pos</td>
                            <td>@participant.DisplayName</td>
                            <td>@ratingLabel</td>
                            <td>
                                <a asp-controller="Profile" asp-action="Details" asp-route-id="@participant.UserId">View profile</a>
                            </td>
                        </tr>
                        pos++;
                    }
                    </tbody>
                </table>
            </div>
        </div>
    }
}

<div class="d-flex flex-wrap gap-2">
    @if (User.Identity?.IsAuthenticated == true)
    {
        if (Model.IsCreator && Model.Activity.Status == FindActivity.Domain.Enums.ActivityStatus.Scheduled)
        {
            <a class="btn btn-outline-primary" asp-action="Edit" asp-route-id="@Model.Activity.Id">Edit</a>
            <a class="btn btn-outline-secondary" asp-action="Duplicate" asp-route-id="@Model.Activity.Id">Duplicate</a>
            <form asp-action="Cancel" asp-route-id="@Model.Activity.Id" method="post">
                <button class="btn btn-outline-danger" type="submit">Cancel activity</button>
            </form>
            if (Model.Activity.StartUtc.AddMinutes(Model.Activity.DurationMinutes) <= DateTime.UtcNow)
            {
                <form asp-action="Complete" asp-route-id="@Model.Activity.Id" method="post">
                    <button class="btn btn-outline-success" type="submit">Mark complete</button>
                </form>
            }
        }
        else if (Model.IsCreator)
        {
            <a class="btn btn-outline-secondary" asp-action="Duplicate" asp-route-id="@Model.Activity.Id">Duplicate</a>
        }
        else if (Model.Activity.Status == FindActivity.Domain.Enums.ActivityStatus.Scheduled)
        {
            if (Model.Activity.IsUserJoined)
            {
                <form asp-action="Leave" asp-route-id="@Model.Activity.Id" method="post">
                    <button class="btn btn-warning" type="submit">Leave</button>
                </form>
            }
            else if (Model.Activity.IsUserWaitlisted)
            {
                <form asp-action="Leave" asp-route-id="@Model.Activity.Id" method="post">
                    <button class="btn btn-outline-warning" type="submit">Leave waitlist</button>
                </form>
            }
            else
            {
                var isFull = Model.Activity.JoinedCount >= Model.Activity.Capacity;
                <form asp-action="Join" asp-route-id="@Model.Activity.Id" method="post">
                    <button class="btn @(isFull ? "btn-outline-success" : "btn-success")" type="submit">
                        @(isFull ? "Join waitlist" : "Join")
                    </button>
                </form>
            }
        }
    }
</div>

@if (Model.CanReviewHost)
{
    <div class="mt-4">
        <a class="btn btn-primary" asp-controller="Reviews" asp-action="Create" asp-route-activityId="@Model.Activity.Id">Leave a review for host</a>
    </div>
}

@if (canReportActivity)
{
    var reportModel = new ReportCreateViewModel
    {
        TargetType = ReportTargetType.Activity,
        TargetActivityId = Model.Activity.Id,
        ReturnUrl = Url.Action("Details", "Activities", new { id = Model.Activity.Id })
    };
    <div class="mt-4">
        <button type="button" class="btn btn-link text-muted p-0" data-bs-toggle="modal" data-bs-target="#reportModal">
            Report this activity
        </button>
    </div>
    <partial name="_ReportModal" model="reportModel" />
}
