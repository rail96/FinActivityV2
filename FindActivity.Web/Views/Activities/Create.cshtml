@model FindActivity.Web.Models.Activities.ActivityFormViewModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = "Create Activity";
    var mapboxToken = Configuration["Mapbox:AccessToken"];
}

<h1>Create Activity</h1>

@if (TempData["DuplicateNotice"] is string duplicateNotice)
{
    <div class="alert alert-info" role="alert">@duplicateNotice</div>
}

<form asp-action="Create" method="post" enctype="multipart/form-data">
    <div class="row g-3">
        <div class="col-md-6">
            <label class="form-label">Title</label>
            <input class="form-control" asp-for="Title" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label" asp-for="CoverImageFile"></label>
            <input class="form-control" type="file" asp-for="CoverImageFile" accept="image/jpeg,image/png,image/webp" />
            <small class="text-muted">JPG, PNG, or WebP. Max 5MB. Optional but recommended.</small>
            <span asp-validation-for="CoverImageFile" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">Category</label>
            <select class="form-select" asp-for="CategoryId" asp-items="Model.Categories"></select>
            <span asp-validation-for="CategoryId" class="text-danger"></span>
        </div>
        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea class="form-control" asp-for="Description" rows="4"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Start (UTC)</label>
            <input class="form-control" type="datetime-local" asp-for="StartUtc" />
            <span asp-validation-for="StartUtc" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Duration (minutes)</label>
            <input class="form-control" asp-for="DurationMinutes" />
            <span asp-validation-for="DurationMinutes" class="text-danger"></span>
        </div>
        <div class="col-md-4">
            <label class="form-label">Capacity</label>
            <input class="form-control" asp-for="Capacity" />
            <span asp-validation-for="Capacity" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">City</label>
            <input class="form-control" asp-for="City" data-city-input readonly />
            <span asp-validation-for="City" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label class="form-label">State</label>
            <input class="form-control" asp-for="State" data-state-input readonly />
            <span asp-validation-for="State" class="text-danger"></span>
        </div>
        <div class="col-md-6 position-relative" data-address-autocomplete data-mapbox-token="@mapboxToken">
            <label class="form-label">Address</label>
            <input class="form-control" asp-for="Address" data-address-input autocomplete="off" />
            <input type="hidden" asp-for="AddressPlaceId" data-place-id-input />
            <input type="hidden" asp-for="Latitude" data-latitude-input />
            <input type="hidden" asp-for="Longitude" data-longitude-input />
            <div class="list-group position-absolute w-100 shadow-sm d-none" data-address-suggestions></div>
            <small class="text-muted d-block mt-1" data-address-help>
                @if (string.IsNullOrWhiteSpace(mapboxToken))
                {
                    @:Mapbox token missing on server. Suggestions disabled.
                }
                else
                {
                    @:Select a suggested Washington address.
                }
            </small>
            <span asp-validation-for="Address" class="text-danger"></span>
        </div>
        <div class="col-md-3">
            <label class="form-label">Minimum age</label>
            <input class="form-control" asp-for="MinAge" />
        </div>
    </div>

    <div class="mt-4 d-flex flex-wrap gap-2">
        <button class="btn btn-primary" type="submit">Create</button>
        <a class="btn btn-secondary" asp-action="Index">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
