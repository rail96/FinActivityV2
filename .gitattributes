# Auto-detect text files and normalize line endings on commit.
* text=auto

# Visual Studio / .NET source is conventionally CRLF on Windows.
*.cs       text eol=crlf diff=csharp
*.cshtml   text eol=crlf
*.csproj   text eol=crlf
*.sln      text eol=crlf
*.props    text eol=crlf
*.targets  text eol=crlf
*.config   text eol=crlf
*.xml      text eol=crlf
*.json     text eol=crlf
*.js       text eol=crlf
*.css      text eol=crlf
*.html     text eol=crlf
*.md       text eol=crlf
*.resx     text eol=crlf

# Shell scripts must stay LF so they run on Linux.
*.sh       text eol=lf
*.bash     text eol=lf

# Treat these as binary.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.zip  binary
*.nupkg binary
*.dll  binary
*.exe  binary
*.pdb  binary
*.snk  binary
